<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.todoapp.controller.MainController"
            stylesheets="@../css/style.css"
            maxHeight="Infinity" maxWidth="Infinity">

    <!-- ===================== TOP: Header & Search ===================== -->
    <top>
        <VBox spacing="0" styleClass="header-bar">
            <Label text="UniTask" styleClass="app-title"/>
            <HBox spacing="12" styleClass="toolbar" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="🔍 Cari tugas..." prefWidth="250" HBox.hgrow="SOMETIMES"/>
                <ChoiceBox fx:id="filterStatusChoiceBox" prefWidth="160"/>
                <Button fx:id="newTaskButton" text="+ Tugas Baru" onAction="#handleShowNewTaskDialog"
                        styleClass="primary-button"/>
                <Button fx:id="refreshButton" text="↻ Refresh" onAction="#handleRefresh"
                        styleClass="refresh-button"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ChoiceBox fx:id="notificationStyleChoiceBox" prefWidth="130"
                           styleClass="notification-style-choice"/>
                <Button fx:id="themeToggleButton" onAction="#handleToggleTheme"
                        styleClass="theme-toggle-button"/>
            </HBox>
        </VBox>
    </top>

    <!-- ===================== LEFT: Task Detail & Calendar ===================== -->
    <left>
        <ScrollPane fitToWidth="true" style="-fx-padding: 0; -fx-border-color: transparent;">
            <VBox spacing="16" styleClass="form-panel detail-panel" prefWidth="340" maxWidth="380" minWidth="300">
                <padding>
                    <Insets top="20" right="18" bottom="20" left="18"/>
                </padding>

                <Label fx:id="detailSectionLabel" text="Detail Tugas" styleClass="section-title"/>

                <VBox fx:id="detailCard" spacing="6" styleClass="detail-card">
                    <Label fx:id="detailTitleLabel" text="Pilih tugas dari tabel" styleClass="detail-title" wrapText="true"/>
                    <Label fx:id="detailMetaLabel" text="Detail tugas akan muncul di sini." styleClass="detail-meta" wrapText="true"/>
                </VBox>

                <GridPane fx:id="detailFactsGrid" hgap="10" vgap="10" styleClass="detail-facts-grid">
                    <Label text="Kategori" styleClass="detail-fact-name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="detailCategoryLabel" text="-" styleClass="detail-fact-value" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Mata Kuliah" styleClass="detail-fact-name" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="detailCourseLabel" text="-" styleClass="detail-fact-value" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Deadline" styleClass="detail-fact-name" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="detailDeadlineLabel" text="-" styleClass="detail-fact-value" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Prioritas" styleClass="detail-fact-name" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="detailPriorityLabel" text="-" styleClass="detail-fact-value" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Status" styleClass="detail-fact-name" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label fx:id="detailStatusLabel" text="-" styleClass="detail-fact-value" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="Lampiran" styleClass="detail-fact-name" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <Label fx:id="detailAttachmentLabel" text="-" styleClass="detail-fact-value" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                </GridPane>

                <VBox fx:id="detailDescriptionBox" spacing="8">
                    <Label text="Deskripsi" styleClass="field-label"/>
                    <TextArea fx:id="detailDescriptionArea" styleClass="detail-description" editable="false" wrapText="true"
                                  prefRowCount="1" maxWidth="Infinity" prefHeight="48" maxHeight="64"/>
                </VBox>

                <Button fx:id="editTaskButton" text="Edit Tugas" onAction="#handleShowEditTaskDialog"
                    maxWidth="200" prefWidth="160" disable="true" styleClass="secondary-button"/>

                <VBox spacing="10" styleClass="calendar-panel">
                    <HBox spacing="8" alignment="CENTER">
                        <Button text="‹" onAction="#handlePreviousMonth" styleClass="calendar-nav-button"/>
                        <Label fx:id="calendarTitleLabel" text="Kalender" styleClass="calendar-title" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="›" onAction="#handleNextMonth" styleClass="calendar-nav-button"/>
                    </HBox>
                    <GridPane fx:id="deadlineCalendarGrid" hgap="6" vgap="6" styleClass="calendar-grid"/>
                </VBox>

                <VBox fx:id="deadlinePreviewBox" spacing="8" styleClass="deadline-preview-panel" visible="false" managed="false">
                    <Label fx:id="deadlinePreviewTitleLabel" text="Preview Deadline" styleClass="deadline-preview-title"/>
                    <VBox fx:id="deadlinePreviewList" spacing="6"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </left>

    <!-- ===================== CENTER: Dashboard + Table List Task ===================== -->
    <center>
        <ScrollPane fitToWidth="true">
            <VBox spacing="14" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <!-- Dashboard: stat cards ringkasan tugas -->
                <HBox spacing="12" styleClass="stats-row">
                    <VBox styleClass="stat-card stat-card-total" spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="TOTAL TUGAS" styleClass="stat-label" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Label fx:id="statTotalLabel" text="0" styleClass="stat-value"/>
                        <Label text="Semua tugas" styleClass="stat-subtitle"/>
                    </VBox>
                    <VBox styleClass="stat-card stat-card-done" spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="SELESAI" styleClass="stat-label" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Label fx:id="statDoneLabel" text="0" styleClass="stat-value"/>
                        <Label text="Tugas selesai" styleClass="stat-subtitle"/>
                    </VBox>
                    <VBox styleClass="stat-card stat-card-progress" spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="IN PROGRESS" styleClass="stat-label" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Label fx:id="statProgressLabel" text="0" styleClass="stat-value"/>
                        <Label text="Sedang berjalan" styleClass="stat-subtitle"/>
                    </VBox>
                    <VBox styleClass="stat-card stat-card-pending" spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="BELUM MULAI" styleClass="stat-label" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Label fx:id="statPendingLabel" text="0" styleClass="stat-value"/>
                        <Label text="Perlu diperhatikan" styleClass="stat-subtitle"/>
                    </VBox>
                    <VBox styleClass="stat-card stat-card-rate" spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="COMPLETION RATE" styleClass="stat-label" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Label fx:id="statCompletionRateLabel" text="0%" styleClass="stat-value"/>
                        <Label text="Dari total tugas" styleClass="stat-subtitle"/>
                    </VBox>
                </HBox>

                <!-- Dashboard: upcoming deadlines (14 hari ke depan) -->
                <VBox spacing="10" styleClass="dashboard-card">
                    <Label text="Upcoming Deadlines (14 hari)" styleClass="dashboard-card-title"/>
                    <VBox fx:id="upcomingDeadlinesBox" spacing="8"/>
                </VBox>

                <TableView fx:id="taskTableView" VBox.vgrow="ALWAYS" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="titleColumn"      text="Judul Tugas"   prefWidth="200" minWidth="130"/>
                        <TableColumn fx:id="categoryColumn"   text="Kategori"      prefWidth="110" minWidth="80"  maxWidth="150"/>
                        <TableColumn fx:id="mataKuliahColumn" text="Mata Kuliah"   prefWidth="140" minWidth="100" maxWidth="200"/>
                        <TableColumn fx:id="deadlineColumn"   text="Tenggat Waktu" prefWidth="120" minWidth="100" maxWidth="140"/>
                        <TableColumn fx:id="priorityColumn"   text="Prioritas"     prefWidth="90"  minWidth="80"  maxWidth="120"/>
                        <TableColumn fx:id="statusColumn"     text="Status"        prefWidth="110" minWidth="80"  maxWidth="140"/>
                        <TableColumn fx:id="attachmentColumn" text="Lampiran"      prefWidth="110" minWidth="90"  maxWidth="170"/>
                    </columns>
                </TableView>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="deleteButton" text="🗑 Hapus Tugas" onAction="#handleDeleteTask" styleClass="danger-button"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- ===================== BOTTOM: Status Bar ===================== -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT">
            <padding>
                <Insets top="8" right="20" bottom="8" left="20"/>
            </padding>
            <Label fx:id="statusBarLabel" text="Siap."/>
        </HBox>
    </bottom>

</BorderPane>